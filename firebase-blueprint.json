{
  "entities": {
    "Section": {
      "title": "Section",
      "description": "App section configuration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "enabled": { "type": "boolean" },
        "order": { "type": "number" },
        "title": { "type": "string" },
        "items": { "type": "array" }
      },
      "required": ["id", "type", "enabled", "order", "title"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Hero section banner",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" },
        "button1": { "type": "string" },
        "button2": { "type": "string" }
      },
      "required": ["title", "subtitle", "description", "order"]
    }
  },
  "firestore": {
    "/sections/{sectionId}": {
      "schema": "Section",
      "description": "Global app sections"
    },
    "/banners/{bannerId}": {
      "schema": "Banner",
      "description": "Hero section banners"
    }
  }
}
